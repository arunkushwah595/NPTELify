# Backend Configuration for Production/Deployment
# These properties should be set as environment variables in Render

# Database Configuration
# Format: jdbc:postgresql://host:port/database
DB_URL=jdbc:postgresql://localhost:5432/nptelify
DB_USERNAME=postgres
DB_PASSWORD=arun5950

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Server Configuration
# Port is automatically set by Render, but can be overridden
# SERVER_PORT=8080

# Logging
logging.level.root=INFO
logging.level.com.backend=DEBUG

# Application Configuration
spring.jpa.show-sql=false
spring.jpa.hibernate.ddl-auto=update
